NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
# Used to build absolute guest invitation URLs embedded in QR codes.
# Falls back to ${req.protocol}://${req.headers.host} when unset.
# Set this in production to your canonical frontend origin.
PUBLIC_BASE_URL=

DATABASE_URL=postgresql://wedlove:wedlove123@localhost:5432/wedlove?schema=public

JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Local file upload fallback works without these.
# Fill in to enable Cloudflare R2 storage:
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wedlove-uploads
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Legacy S3 config (kept for backward compatibility, not used by new upload)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=wedlove-uploads
AWS_REGION=ap-southeast-1
